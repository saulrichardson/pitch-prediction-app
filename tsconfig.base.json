{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pitch/domain": ["packages/domain/src/index.ts"],
      "@pitch/domain/*": ["packages/domain/src/*"],
      "@pitch/db": ["packages/db/src/index.ts"],
      "@pitch/db/*": ["packages/db/src/*"]
    }
  }
}
